generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("MYSQL_URL")
}

// ── 사용자 · 인증 ────────────────────────────────────────────────

model User {
  id               Int            @id @default(autoincrement())
  email            String         @unique
  passwordHash     String
  totpSecret       String?
  failedLoginCount Int            @default(0)
  lockedUntil      DateTime?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  refreshTokens    RefreshToken[]

  @@map("users")
}

model RefreshToken {
  id        Int       @id @default(autoincrement())
  userId    Int
  tokenHash String    @unique
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("refresh_tokens")
}

// ── 설정 ─────────────────────────────────────────────────────────

model Setting {
  key       String   @id
  value     String   @db.Text
  isSecret  Boolean  @default(false)
  updatedAt DateTime @updatedAt

  @@map("settings")
}

// ── 사이트 · 플랫폼 연결 ─────────────────────────────────────────

enum Platform {
  WORDPRESS
  BLOGGER
  NAVER_BLOG
  TISTORY
  INSTAGRAM
}

model Site {
  id          Int                  @id @default(autoincrement())
  name        String
  platform    Platform
  url         String?
  isActive    Boolean              @default(true)
  config      Json?
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt
  connections PlatformConnection[]
  articles    Article[]
  publishJobs PublishJob[]

  @@map("sites")
}

model PlatformConnection {
  id                   Int       @id @default(autoincrement())
  siteId               Int
  kind                 String
  encryptedCredentials String?   @db.Text
  status               String    @default("UNKNOWN")
  lastCheckedAt        DateTime?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
  site                 Site      @relation(fields: [siteId], references: [id], onDelete: Cascade)

  @@index([siteId])
  @@map("platform_connections")
}

// ── 키워드 ───────────────────────────────────────────────────────

enum KeywordStatus {
  RECOMMENDED
  SAVED
  EXCLUDED
  USED
}

model Keyword {
  id              Int                          @id @default(autoincrement())
  text            String
  category        String?
  sourceType      String? // ISSUE | EVERGREEN | REVENUE | SEARCH_CONSOLE | MANUAL
  searchIntent    String?
  status          KeywordStatus                @default(RECOMMENDED)
  createdAt       DateTime                     @default(now())
  updatedAt       DateTime                     @updatedAt
  metrics         KeywordMetric[]
  recommendations DailyKeywordRecommendation[]
  articles        Article[]
  products        Product[]
  trends          KeywordTrend[]
  citations       BlogCitation[]

  @@unique([text])
  @@map("keywords")
}

/**
 * 키워드 수집 시계열 스냅샷 (append-only 빅데이터용).
 * 하루 4회 수집마다 키워드별로 한 행씩 누적 기록해, 나중에 년/월/일 단위로 트렌드를 분석할 수 있다.
 * DailyKeywordRecommendation은 (keyword,date) 유니크라 같은 날 덮어써 시간대별이 유실되지만,
 * 이 표는 collectedAt으로 4회/일 해상도까지 보존한다. keywordText를 비정규화해 키워드가 삭제돼도 기록이 남는다.
 */
model KeywordTrend {
  id               Int      @id @default(autoincrement())
  keywordId        Int?
  keywordText      String // 비정규화 — 키워드 삭제돼도 기록 보존
  category         String?
  sourceType       String?
  date             DateTime @db.Date // 수집 일자 (KST 기준)
  year             Int
  month            Int
  day              Int
  collectedAt      DateTime @default(now()) // 수집 시각 (하루 4회 구분)
  trigger          String // cron | manual
  searchVolume     Int? // 대표 검색량 (네이버 우선, 없으면 구글)
  naverSearches    Int?
  googleSearches   Int?
  competitionScore Int?
  totalDocs        Int?
  revenueScore     Int?
  valueScore       Int?
  opportunityScore Int?
  finalScore       Int?
  rank             Int?
  keyword          Keyword? @relation(fields: [keywordId], references: [id], onDelete: SetNull)

  @@index([date])
  @@index([year, month])
  @@index([keywordText])
  @@map("keyword_trends")
}

/**
 * 네이버 블로그 검색 상위 글의 AI 브리핑 인용수 스냅샷 (append-only).
 *
 * 네이버는 블로그 검색 결과에 블로거의 누적 AI 브리핑 인용수 배지("403만 인용")를 노출한다.
 * 우리 키워드로 블로그 탭을 매일 1회 긁어 (키워드 × 상위 글) 인용수를 쌓으면
 * ① 어떤 글·블로거가 AI에 잘 인용되는지 벤치마크할 수 있고
 * ② 같은 글의 인용수 증가 추이를 시계열로 볼 수 있다.
 *
 * 인용수는 글이 아니라 '블로거(채널)' 누적치라, citedCount는 blogId 기준으로 해석해야 한다.
 * (키워드, 날짜, 글URL) 유니크 — 하루 여러 번 돌려도 같은 날은 덮어쓴다.
 */
model BlogCitation {
  id          Int      @id @default(autoincrement())
  keywordId   Int?
  keywordText String // 비정규화 — 키워드 삭제돼도 기록 보존
  date        DateTime @db.Date // 수집 일자 (KST)
  collectedAt DateTime @default(now())
  rank        Int // 블로그 탭 노출 순위 (1부터)
  title       String   @db.Text
  // MySQL 은 TEXT 를 유니크 인덱스에 못 쓴다 → 네이버 글 URL 은 짧으므로 VARCHAR 로 둔다.
  url         String   @db.VarChar(255)
  blogId      String // blog.naver.com/<blogId>
  blogName    String? // 표시 이름
  citedCount  BigInt? // 블로거 누적 AI 브리핑 인용수 (배지 없으면 null)
  citedLabel  String? // 원문 배지 텍스트 ("403만 인용")
  postedAt    String? // "2주 전" 등 상대 표기 (네이버가 상대값만 준다)
  keyword     Keyword? @relation(fields: [keywordId], references: [id], onDelete: SetNull)

  @@unique([keywordText, date, url])
  @@index([date])
  @@index([blogId])
  @@index([citedCount])
  @@map("blog_citations")
}

/**
 * 인용 학습 결과 — AI 브리핑에 인용된 글들을 실제로 읽고 뽑아낸 인사이트.
 *
 * 네이버 공식 5원칙은 원론이라 프롬프트에 그대로 넣어도 글이 안 바뀐다.
 * 대신 그 키워드에서 진짜 인용되는 글들의 말투·구조·정보 담는 방식·빈 각도를 뽑아
 * 글 생성 프롬프트에 주입한다. (data = CitationInsightData)
 */
model CitationInsight {
  id           Int      @id @default(autoincrement())
  keywordText  String   @unique
  data         Json // whyCited / tone / structure / infoStyle / coveredAngles / gaps / writingRules
  postsStudied Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("citation_insights")
}

/**
 * 사용자가 직접 등록하는 제휴 상품 풀 (쿠팡 파트너스 검색 API가 없어 수동 등록).
 * 등록 시 오늘의 키워드와 매칭해 두면, 그 키워드의 자동 글에 상품 배너가 삽입된다.
 */
model Product {
  id               Int      @id @default(autoincrement())
  source           String // COUPANG | BRANDCONNECT
  externalKey      String?  @db.VarChar(64) // 크롤 업서트 키 — 쿠팡: "productId:vendorItemId" (수동 등록은 null)
  name             String
  brand            String?
  price            Int?
  originPrice      Int? // 할인 전 가격 (배너 취소선·할인율 표기용)
  imageUrl         String?  @db.Text
  productUrl       String   @db.Text
  description      String?  @db.Text
  categoryName     String? // 쿠팡 파트너스 카테고리 (뷰티·가전디지털…) — 상품 페이지 필터용
  ratingCount      Int? // 리뷰 수 — 매칭 후보가 여럿일 때 신뢰도 높은 상품 우선
  isRocket         Boolean  @default(false)
  status           String   @default("ACTIVE") // ACTIVE | USED | DISABLED
  matchedKeywordId Int?
  matchedAt        DateTime? // 키워드에 매칭된 시각 (미매칭→매칭 전환 시 갱신, 알림·뱃지용)
  matchedKeyword   Keyword? @relation(fields: [matchedKeywordId], references: [id], onDelete: SetNull)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@unique([source, externalKey])
  @@index([status])
  @@index([matchedKeywordId])
  @@index([categoryName])
  @@map("products")
}

/** 대량 매칭 히스토리 — 붙여넣은 상품 목록에서 키워드와 매칭된 상품을 누적 저장(무한스크롤·중복제거). */
model BulkMatchHit {
  id          Int      @id @default(autoincrement())
  source      String // COUPANG | BRANDCONNECT
  name        String   @db.VarChar(191) // 유니크 인덱스 대상이라 길이 제한 (bulk-match는 120자 이하만 수집)
  keyword     String   @db.VarChar(191)
  score       Int      @default(0)
  usedAt      DateTime? // 스케줄러가 이 매칭으로 글을 자동 생성한 시각 (소진 처리)
  articleId   Int? // 생성된 글 ID (히스토리에서 바로가기)
  createdAt   DateTime @default(now())

  @@unique([source, name], name: "source_name")
  @@index([source, createdAt])
  @@index([usedAt])
  @@map("bulk_match_hits")
}

model KeywordMetric {
  id                 Int      @id @default(autoincrement())
  keywordId          Int
  date               DateTime @db.Date
  source             String // GOOGLE_ADS | NAVER_SEARCHAD | ...
  avgMonthlySearches Int?
  cpcMicros          BigInt?
  currency           String?
  competition        String?
  competitionIndex   Int?
  raw                Json?
  createdAt          DateTime @default(now())
  keyword            Keyword  @relation(fields: [keywordId], references: [id], onDelete: Cascade)

  @@unique([keywordId, date, source])
  @@map("keyword_metrics")
}

model DailyKeywordRecommendation {
  id               Int      @id @default(autoincrement())
  keywordId        Int
  date             DateTime @db.Date
  rank             Int
  reason           String?  @db.Text
  revenueScore     Int?
  valueScore       Int?
  opportunityScore Int?
  finalScore       Int?
  data             Json?
  createdAt        DateTime @default(now())
  keyword          Keyword  @relation(fields: [keywordId], references: [id], onDelete: Cascade)

  @@unique([keywordId, date])
  @@index([date])
  @@map("daily_keyword_recommendations")
}

// ── 콘텐츠 ───────────────────────────────────────────────────────

enum ArticleStatus {
  DRAFT
  REVIEW
  APPROVED
  SCHEDULED
  PUBLISHED
  FAILED
}

model Article {
  id              Int               @id @default(autoincrement())
  keywordId       Int?
  siteId          Int?
  title           String
  slug            String?
  language        String            @default("ko")
  articleType     String            @default("guide")
  status          ArticleStatus     @default(DRAFT)
  metaTitle       String?
  metaDescription String?           @db.Text
  excerpt         String?           @db.Text
  contentMarkdown String?           @db.LongText
  contentHtml     String?           @db.LongText
  qualityScore    Int?
  qualityReport   Json?
  adSource        String? // 삽입된 제휴 광고 플랫폼: COUPANG | BRANDCONNECT (없으면 null)
  adProduct       String? // 삽입된 제휴 상품명 (글 목록에서 어떤 광고인지 표시용)
  extensionDoneAt DateTime? // 확장에서 '발행완료' 버튼을 눌러 대기목록에서 숨긴 시각 (반자동 수동 체크)
  instagram       Json? // 인스타그램 캐러셀용: { slides:[{position,title,summary}x3], caption, hashtags:[...] } (이미지는 블로그 3장 재사용)
  publishAt       DateTime?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  keyword         Keyword?          @relation(fields: [keywordId], references: [id], onDelete: SetNull)
  site            Site?             @relation(fields: [siteId], references: [id], onDelete: SetNull)
  versions        ArticleVersion[]
  sources         ArticleSource[]
  schemas         ArticleSchema[]
  media           MediaAsset[]
  publishJobs     PublishJob[]
  categories      ArticleCategory[]
  tags            ArticleTag[]
  analytics       AnalyticsDaily[]
  searchQueries   SearchQueryDaily[]

  @@index([status])
  @@map("articles")
}

model ArticleVersion {
  id              Int      @id @default(autoincrement())
  articleId       Int
  version         Int
  title           String
  contentMarkdown String?  @db.LongText
  contentHtml     String?  @db.LongText
  changeNote      String?
  createdAt       DateTime @default(now())
  article         Article  @relation(fields: [articleId], references: [id], onDelete: Cascade)

  @@unique([articleId, version])
  @@map("article_versions")
}

model ArticleSource {
  id          Int       @id @default(autoincrement())
  articleId   Int
  url         String    @db.Text
  title       String?
  publisher   String?
  publishedAt DateTime?
  verifiedAt  DateTime?
  status      String    @default("PENDING") // PENDING | VERIFIED | BROKEN
  createdAt   DateTime  @default(now())
  article     Article   @relation(fields: [articleId], references: [id], onDelete: Cascade)

  @@index([articleId])
  @@map("article_sources")
}

model ArticleSchema {
  id         Int      @id @default(autoincrement())
  articleId  Int
  schemaType String // Article | NewsArticle | BlogPosting | FAQPage | Product | Review | HowTo | BreadcrumbList
  jsonLd     Json
  isEnabled  Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  article    Article  @relation(fields: [articleId], references: [id], onDelete: Cascade)

  @@index([articleId])
  @@map("article_schemas")
}

model Category {
  id       Int               @id @default(autoincrement())
  name     String            @unique
  slug     String            @unique
  articles ArticleCategory[]

  @@map("categories")
}

model Tag {
  id       Int          @id @default(autoincrement())
  name     String       @unique
  slug     String       @unique
  articles ArticleTag[]

  @@map("tags")
}

model ArticleCategory {
  articleId  Int
  categoryId Int
  article    Article  @relation(fields: [articleId], references: [id], onDelete: Cascade)
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@id([articleId, categoryId])
  @@map("article_categories")
}

model ArticleTag {
  articleId Int
  tagId     Int
  article   Article @relation(fields: [articleId], references: [id], onDelete: Cascade)
  tag       Tag     @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([articleId, tagId])
  @@map("article_tags")
}

model MediaAsset {
  id          Int      @id @default(autoincrement())
  articleId   Int?
  kind        String   @default("CONTENT") // FEATURED | CONTENT
  prompt      String?  @db.Text
  altText     String?
  caption     String?
  fileName    String?
  originalUrl String?  @db.Text
  webpUrl     String?  @db.Text
  width       Int?
  height      Int?
  bytes       Int?
  position    Int?
  characterKeys String? // 이 이미지에 등장하는 레퍼런스 캐릭터 키 (콤마 구분)
  createdAt   DateTime @default(now())
  article     Article? @relation(fields: [articleId], references: [id], onDelete: SetNull)

  @@index([articleId])
  @@map("media_assets")
}

// ── 스케줄 · 발행 ────────────────────────────────────────────────

model Schedule {
  id        Int       @id @default(autoincrement())
  name      String
  jobType   String // KEYWORD_COLLECT | ARTICLE_GENERATE | PUBLISH | ANALYTICS_SYNC
  cron      String
  isActive  Boolean   @default(true)
  config    Json?
  lastRunAt DateTime?
  nextRunAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@map("schedules")
}

enum PublishJobStatus {
  QUEUED
  RUNNING
  SUCCEEDED
  FAILED
  CANCELED
}

model PublishJob {
  id           Int              @id @default(autoincrement())
  articleId    Int
  siteId       Int?
  platform     Platform
  status       PublishJobStatus @default(QUEUED)
  scheduledAt  DateTime?
  startedAt    DateTime?
  finishedAt   DateTime?
  publishedUrl String?          @db.Text
  error        String?          @db.Text
  retryCount   Int              @default(0)
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  article      Article          @relation(fields: [articleId], references: [id], onDelete: Cascade)
  site         Site?            @relation(fields: [siteId], references: [id], onDelete: SetNull)
  logs         PublishLog[]

  @@index([status])
  @@map("publish_jobs")
}

model PublishLog {
  id           Int        @id @default(autoincrement())
  publishJobId Int
  level        String     @default("INFO")
  message      String     @db.Text
  createdAt    DateTime   @default(now())
  publishJob   PublishJob @relation(fields: [publishJobId], references: [id], onDelete: Cascade)

  @@index([publishJobId])
  @@map("publish_logs")
}

// ── 사용량 · 확장 · 분석 ─────────────────────────────────────────

model ModelUsageLog {
  id           Int      @id @default(autoincrement())
  provider     String // anthropic | gemini | google-ads | ...
  model        String
  operation    String
  inputTokens  Int?
  outputTokens Int?
  costMicros   BigInt?
  articleId    Int?
  createdAt    DateTime @default(now())

  @@index([provider, createdAt])
  @@map("model_usage_logs")
}

model ExtensionDevice {
  id         Int       @id @default(autoincrement())
  name       String
  tokenHash  String    @unique
  lastSeenAt DateTime?
  createdAt  DateTime  @default(now())

  @@map("extension_devices")
}

model AnalyticsDaily {
  id              Int      @id @default(autoincrement())
  date            DateTime @db.Date
  articleId       Int?
  source          String // SEARCH_CONSOLE | GA4 | ADSENSE
  impressions     Int?
  clicks          Int?
  pageviews       Int?
  avgPosition     Float?
  adRevenueMicros BigInt?
  rpmMicros       BigInt?
  raw             Json?
  createdAt       DateTime @default(now())
  article         Article? @relation(fields: [articleId], references: [id], onDelete: SetNull)

  @@unique([date, articleId, source])
  @@map("analytics_daily")
}

/// 제휴 실적 — 네이버 쇼핑커넥트 / 쿠팡 파트너스의 **일별 유입·매출·수수료**.
///
/// ⚠️ 두 곳 다 **공개 API가 없다**(쿠팡은 Open API 키 발급이 중지됐고, 브랜드커넥트는 애초에 API가 없다).
///    유일한 길은 **로그인된 브라우저**로 대시보드가 스스로 부르는 JSON을 그대로 받아오는 것이다.
///    그래서 확장 프로그램이 수집해 서버로 보낸다 (네이버·티스토리 발행과 같은 구조).
///
/// 실적은 소급 정정된다(주문 취소·확정 지연) → 같은 (날짜, 출처)는 **덮어쓴다**.
model AffiliateDaily {
  id          Int      @id @default(autoincrement())
  date        DateTime @db.Date
  source      String // NAVER_CONNECT | COUPANG
  clicks      Int      @default(0) // 유입수 (커넥트 accessCnt)
  orders      Int      @default(0) // 주문 건수
  salesAmount Int      @default(0) // 거래액 (원)
  commission  Int      @default(0) // 수수료 = 내 수익 (원)
  raw         Json?
  collectedAt DateTime @default(now())

  @@unique([date, source])
  @@index([date])
  @@map("affiliate_daily")
}

/// 유입 쿼리 — **사람들이 실제로 검색해서 내 글에 들어온 말.**
///
/// `analytics_daily` 는 "이 글이 몇 번 노출됐나"만 안다. 어떤 검색어로 들어왔는지는 모른다.
/// 그런데 자가학습에 정말 필요한 건 그쪽이다: 내가 "무선이어폰 추천"이라고 썼는데
/// 사람들은 "이어폰 배터리 오래가는거"로 들어온다면, **다음 글은 그 말로 써야 한다.**
///
/// ⚠️ 글과 못 이은 쿼리는 저장하지 않는다 (목록·태그 페이지의 쿼리는 글의 성과가 아니다).
model SearchQueryDaily {
  id          Int      @id @default(autoincrement())
  date        DateTime @db.Date
  articleId   Int
  query       String   @db.VarChar(255)
  impressions Int
  clicks      Int
  position    Float?
  createdAt   DateTime @default(now())
  article     Article  @relation(fields: [articleId], references: [id], onDelete: Cascade)

  @@unique([date, articleId, query])
  @@index([articleId])
  @@map("search_query_daily")
}
