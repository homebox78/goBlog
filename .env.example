NODE_ENV=development

WEB_URL=http://localhost:5173
API_URL=http://localhost:8787
PORT=8787

MYSQL_URL=mysql://publisher:password@localhost:3306/publisher

REDIS_URL=redis://localhost:6379

# 최초 기동 시 관리자 계정이 없으면 이 값으로 생성된다.
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-this-password

# 세션/토큰 서명 키 (긴 무작위 문자열)
SESSION_SECRET=replace-with-long-random-value
# 설정 비밀값 AES-256-GCM 암호화 키 (32바이트 이상 문자열)
MASTER_ENCRYPTION_KEY=replace-with-32-byte-secret
# Chrome 확장 프로그램 페어링 토큰
EXTENSION_TOKEN=replace-with-extension-token

S3_ENDPOINT=
S3_REGION=
S3_BUCKET=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_PUBLIC_URL=
